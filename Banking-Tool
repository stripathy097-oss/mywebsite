    <script>
        // Tailwind script init
        function initTailwind() {
            return {
                config(userConfig = {}) {
                    return {
                        configUser: userConfig,
                        theme: {
                            extend: {}
                        }
                    }
                },
                theme(userConfig = {}) {
                    return {
                        ...this.defaultTheme(),
                        ...this.config(userConfig).theme
                    }
                },
                defaultTheme() {
                    return {
                        extend: {}
                    }
                }
            }
        }
        
        // Global chart variables
        let emiChartInstance = null;
        let compareChartInstance = null;

        function smoothScrollTo(id) {
            document.getElementById(id).scrollIntoView({ behavior: 'smooth' });
        }

        // Theme toggle
        function toggleTheme() {
            // Simple dark mode already applied, can extend if needed
            alert("Bhai, yeh already dark theme mein hai! Future mein light mode bhi add kar denge 😎");
        }

        // Loan type selection
        let currentLoanType = 0; // 0 = Home, 1 = Car
        
        function selectLoanType(type) {
            currentLoanType = type;
            
            // Update buttons
            const homeBtn = document.getElementById('homeBtn');
            const carBtn = document.getElementById('carBtn');
            
            if (type === 0) {
                homeBtn.classList.add('active', 'border-emerald-500', 'bg-emerald-500/10');
                homeBtn.classList.remove('border-white/30');
                carBtn.classList.remove('active', 'border-emerald-500', 'bg-emerald-500/10');
                carBtn.classList.add('border-white/30');
                
                // Default values for Home
                document.getElementById('rate').value = 8.5;
                document.getElementById('tenure').value = 20;
            } else {
                carBtn.classList.add('active', 'border-emerald-500', 'bg-emerald-500/10');
                carBtn.classList.remove('border-white/30');
                homeBtn.classList.remove('active', 'border-emerald-500', 'bg-emerald-500/10');
                homeBtn.classList.add('border-white/30');
                
                // Default values for Car
                document.getElementById('rate').value = 9.5;
                document.getElementById('tenure').value = 5;
            }
        }

        // EMI Calculator
        function calculateEMI() {
            const principal = parseFloat(document.getElementById('principal').value) || 0;
            const annualRate = parseFloat(document.getElementById('rate').value) || 0;
            const years = parseFloat(document.getElementById('tenure').value) || 0;
            
            if (!principal || !annualRate || !years) {
                alert("Sab fields bhar do bhai!");
                return;
            }
            
            const monthlyRate = annualRate / 12 / 100;
            const numPayments = years * 12;
            
            let emi = 0;
            if (monthlyRate === 0) {
                emi = principal / numPayments;
            } else {
                emi = principal * monthlyRate * Math.pow(1 + monthlyRate, numPayments) / 
                      (Math.pow(1 + monthlyRate, numPayments) - 1);
            }
            
            const totalPayable = emi * numPayments;
            const totalInterest = totalPayable - principal;
            
            // Show results
            document.getElementById('emiPlaceholder').classList.add('hidden');
            const resultsDiv = document.getElementById('emiResults');
            resultsDiv.classList.remove('hidden');
            
            document.getElementById('emiValue').textContent = '₹ ' + Math.round(emi).toLocaleString('en-IN');
            document.getElementById('totalInterest').textContent = '₹ ' + Math.round(totalInterest).toLocaleString('en-IN');
            document.getElementById('totalPayable').textContent = '₹ ' + Math.round(totalPayable).toLocaleString('en-IN');
            
            // Pie Chart
            const ctx = document.getElementById('emiChart');
            
            if (emiChartInstance) emiChartInstance.destroy();
            
            emiChartInstance = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Principal', 'Interest'],
                    datasets: [{
                        data: [principal, totalInterest],
                        backgroundColor: ['#10b981', '#eab308'],
                        borderColor: '#0f172a',
                        borderWidth: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: { position: 'bottom', labels: { color: '#e2e8f0', padding: 25, font: { size: 15 } } }
                    }
                }
            });
        }

        // FD Calculator
        function calculateFD() {
            const amount = parseFloat(document.getElementById('fdAmount').value) || 0;
            const rate = parseFloat(document.getElementById('fdRate').value) || 0;
            const years = parseFloat(document.getElementById('fdTenure').value) || 0;
            
            if (!amount || !rate || !years) return;
            
            // Quarterly compounding (standard in India)
            const quarterlyRate = rate / 4 / 100;
            const numQuarters = years * 4;
            const maturity = amount * Math.pow(1 + quarterlyRate, numQuarters);
            const interest = maturity - amount;
            
            const resultDiv = document.getElementById('fdResult');
            resultDiv.classList.remove('hidden');
            document.getElementById('fdMaturity').textContent = '₹ ' + Math.round(maturity).toLocaleString('en-IN');
            document.getElementById('fdInterest').textContent = '₹ ' + Math.round(interest).toLocaleString('en-IN');
            
            // Trigger comparison if RD also calculated
            if (!document.getElementById('rdResult').classList.contains('hidden')) {
                createComparisonChart();
            }
        }

        // RD Calculator
        function calculateRD() {
            const monthly = parseFloat(document.getElementById('rdMonthly').value) || 0;
            const rate = parseFloat(document.getElementById('rdRate').value) || 0;
            const years = parseFloat(document.getElementById('rdTenure').value) || 0;
            
            if (!monthly || !rate || !years) return;
            
            const n = years * 12; // total months
            
            // Standard RD formula used by most Indian banks (simple interest on cumulative deposits)
            const interest = monthly * n * (n + 1) / 2 * (rate / 1200);
            const maturity = monthly * n + interest;
            const totalInvested = monthly * n;
            
            const resultDiv = document.getElementById('rdResult');
            resultDiv.classList.remove('hidden');
            document.getElementById('rdMaturity').textContent = '₹ ' + Math.round(maturity).toLocaleString('en-IN');
            document.getElementById('rdInterest').textContent = '₹ ' + Math.round(interest).toLocaleString('en-IN');
            document.getElementById('rdInvested').textContent = '₹ ' + Math.round(totalInvested).toLocaleString('en-IN');
            
            // Trigger comparison if FD also calculated
            if (!document.getElementById('fdResult').classList.contains('hidden')) {
                createComparisonChart();
            }
        }

        // Comparison Chart
        function createComparisonChart() {
            const fdMaturity = parseFloat(document.getElementById('fdMaturity').textContent.replace(/[₹, ]/g, '')) || 0;
            const rdMaturity = parseFloat(document.getElementById('rdMaturity').textContent.replace(/[₹, ]/g, '')) || 0;
            
            if (!fdMaturity || !rdMaturity) return;
            
            const ctx = document.getElementById('compareChart');
            
            if (compareChartInstance) compareChartInstance.destroy();
            
            compareChartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Fixed Deposit', 'Recurring Deposit'],
                    datasets: [{
                        label: 'Maturity Amount (₹)',
                        data: [fdMaturity, rdMaturity],
                        backgroundColor: ['#10b981', '#eab308'],
                        borderRadius: 12,
                        barThickness: 60
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: { grid: { color: '#334155' }, ticks: { color: '#e2e8f0' } },
                        x: { grid: { color: '#334155' }, ticks: { color: '#e2e8f0' } }
                    }
                }
            });
            
            // Winner text
            const winner = fdMaturity > rdMaturity ? 'FD' : 'RD';
            const diff = Math.abs(fdMaturity - rdMaturity);
            document.getElementById('winnerText').innerHTML = `
                <span class="text-emerald-400">🎉 ${winner} better hai is case mein!</span><br>
                Difference: ₹ ${diff.toLocaleString('en-IN')}
            `;
        }

        // Eligibility Checker
        function checkEligibility() {
            const salary = parseFloat(document.getElementById('salary').value) || 0;
            const existingEmi = parseFloat(document.getElementById('existingEmi').value) || 0;
            const loanType = parseInt(document.getElementById('loanTypeElig').value);
            
            if (!salary) {
                alert("Salary daal do bhai!");
                return;
            }
            
            // 50% salary rule (common bank thumb rule)
            let maxEmi = (salary * 0.5) - existingEmi;
            if (maxEmi < 0) maxEmi = 0;
            
            let rate = 8.5;
            let years = 20;
            
            if (loanType === 1) { // Car
                rate = 9.5;
                years = 5;
            }
            
            // Reverse EMI formula to get max loan
            const monthlyRate = rate / 12 / 100;
            const numPayments = years * 12;
            
            let maxLoan = 0;
            if (monthlyRate === 0) {
                maxLoan = maxEmi * numPayments;
            } else {
                maxLoan = maxEmi * (1 - Math.pow(1 + monthlyRate, -numPayments)) / monthlyRate;
            }
            
            // Show result
            const resultDiv = document.getElementById('eligibilityResult');
            resultDiv.classList.remove('hidden');
            
            document.getElementById('maxLoanAmount').textContent = '₹ ' + Math.round(maxLoan).toLocaleString('en-IN');
            document.getElementById('maxEmiText').textContent = '₹ ' + Math.round(maxEmi).toLocaleString('en-IN');
        }

        // Keyboard support
        function addKeyboardSupport() {
            document.addEventListener('keypress', function(e) {
                if (e.key === "Enter") {
                    const activeSection = document.querySelector('.tool-card:hover');
                    if (activeSection) {
                        // Auto calculate based on which section
                        if (document.getElementById('emiResults').parentElement.parentElement.contains(activeSection)) {
                            calculateEMI();
                        }
                    }
                }
            });
        }

        // Initialize everything
        window.onload = function() {
            initTailwind();
            selectLoanType(0); // Default Home Loan
            addKeyboardSupport();
            
            console.log('%c✅ The Common Man\'s Banking Suite loaded successfully!', 'color:#10b981; font-size:18px; font-weight:bold');
            console.log('Bhai, ab full website ready hai. Bas copy-paste karke index.html bana lo!');
        };
    </script>
</body>
